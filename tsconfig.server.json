{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": ".server-out",
    "paths": {"@/*": ["./*"]}
  },
  "include": ["server.ts", "lib/**/*.ts", "types/**/*.ts"]
}
